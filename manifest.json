{
  "manifest_version": 3,
  "name": "ChatGPT Audio Downloader",
  "version": "1.0",
  "description": "Adds a native-looking 'Download Audio' button to the ChatGPT context menu.",
  "icons": {
  },
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "injected.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": []
}
